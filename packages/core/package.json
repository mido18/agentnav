{
  "name": "@agentnav/core",
  "version": "0.1.0",
  "description": "Core schemas, generators, safety rules, and readiness scoring for AgentNav, the agent-readiness layer for React and Next.js.",
  "type": "module",
  "license": "MIT",
  "author": "AgentNav contributors",
  "homepage": "https://github.com/mido18/agentnav#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mido18/agentnav.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/mido18/agentnav/issues"
  },
  "keywords": [
    "agentnav",
    "ai-agents",
    "agent-readiness",
    "llms-txt",
    "json-ld",
    "typescript",
    "schema-org",
    "developer-tools"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
