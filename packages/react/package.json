{
  "name": "@agentnav/react",
  "version": "0.1.1",
  "description": "React components for making websites agent-readable with data-agent attributes, safe actions, entities, fields, forms, and runtime scanning.",
  "type": "module",
  "license": "MIT",
  "author": "AgentNav contributors",
  "homepage": "https://github.com/mido18/agentnav#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mido18/agentnav.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/mido18/agentnav/issues"
  },
  "keywords": [
    "react",
    "nextjs",
    "ai-agents",
    "agent-readiness",
    "llms-txt",
    "json-ld",
    "typescript",
    "seo",
    "accessibility"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@agentnav/core": "workspace:*",
    "@agentnav/scanner": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
