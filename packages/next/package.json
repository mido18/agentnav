{
  "name": "@agentnav/next",
  "version": "0.1.0",
  "description": "Next.js route helpers for publishing llms.txt, agent.json, actions.json, and JSON-LD for AI agent-ready sites.",
  "type": "module",
  "license": "MIT",
  "author": "AgentNav contributors",
  "homepage": "https://github.com/mido18/agentnav#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mido18/agentnav.git",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/mido18/agentnav/issues"
  },
  "keywords": [
    "nextjs",
    "react",
    "ai-agents",
    "agent-readiness",
    "llms-txt",
    "well-known",
    "json-ld",
    "typescript",
    "seo"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@agentnav/core": "workspace:*"
  },
  "peerDependencies": {
    "next": ">=14.0.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
