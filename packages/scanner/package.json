{
  "name": "@agentnav/scanner",
  "version": "0.1.1",
  "description": "Browser runtime scanner that scores pages and detects agent-readable metadata, actions, forms, JSON-LD, and warnings.",
  "type": "module",
  "license": "MIT",
  "author": "AgentNav contributors",
  "homepage": "https://github.com/mido18/agentnav#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mido18/agentnav.git",
    "directory": "packages/scanner"
  },
  "bugs": {
    "url": "https://github.com/mido18/agentnav/issues"
  },
  "keywords": [
    "agentnav",
    "ai-agents",
    "agent-readiness",
    "browser-scanner",
    "llms-txt",
    "json-ld",
    "forms",
    "developer-tools"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./browser": "./dist/index.global.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@agentnav/core": "workspace:*"
  },
  "devDependencies": {
    "jsdom": "^26.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
